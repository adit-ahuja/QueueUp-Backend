# App
NODE_ENV=development
PORT=3000

# PostgreSQL (AWS RDS)
DB_HOST=queueup-db.cxq8aim2kbgq.ap-southeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=queueup
DB_USER=queueup_admin
DB_PASSWORD=your_rds_password

# Redis Cloud
REDIS_HOST=redis-13649.crce283.ap-south-1-2.ec2.cloud.redislabs.com
REDIS_PORT=13649
REDIS_PASSWORD=your_redis_password

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_SSzwj0HwyQBnrE
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Get from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Firebase (Rohit Bhaiya fills these)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Ghost Order Protection (Pushpak Bhaiya)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GHOST_SECRET=REPLACE_WITH_32_BYTE_RANDOM_HEX
GHOST_WINDOW_MS=30000

# NLP Service (Rohit Bhaiya)
NLP_INTERNAL_SECRET=queueup_nlp_secret_2026
NLP_SERVICE_URL=http://localhost:8001